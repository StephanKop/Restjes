{
  "name": "kliekjesclub",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "generate:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID 2>/dev/null > packages/supabase/src/database.types.ts",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "jsonwebtoken": "^9.0.3",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.1.0"
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "version": "1.0.0",
  "dependencies": {
    "expo": "~54.0.33",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
